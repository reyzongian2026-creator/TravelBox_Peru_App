{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/icons/*",
      "/*.css",
      "/*.gif",
      "/*.ico",
      "/*.jpg",
      "/*.js",
      "/*.json",
      "/*.png",
      "/*.svg",
      "/*.txt",
      "/*.wasm",
      "/canvaskit/*",
      "/flutter_service_worker.js"
    ]
  },
  "mimeTypes": {
    ".wasm": "application/wasm"
  },
  "routes": [
    {
      "route": "/auth/callback",
      "rewrite": "/index.html"
    }
  ],
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  }
}
